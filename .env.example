# Required in production
JWT_SECRET=change-me-to-a-long-random-string

# Bzzoiro BSD — https://sports.bzzoiro.com/register (free token)
# Squads, live scores, match results, first scorer
BZZOIRO_API_TOKEN=your-bzzoiro-token-here
# World Cup 2026 tournament on Bzzoiro (id 27 — not qualification leagues)
BZZOIRO_LEAGUE_ID=27

# Sync every 10 minutes (milliseconds)
RESULTS_SYNC_INTERVAL_MS=600000
# Live score poll interval (milliseconds, min ~30s per Bzzoiro cache)
LIVE_SCORES_INTERVAL_MS=60000
# Max incident requests per sync (first scorer)
RESULTS_SYNC_MAX_EVENTS=15
# Squad lookup order (default: local cache first, then API)
# SQUAD_PROVIDER_ORDER=local,bzzoiro
# Delay between squad export API calls (ms)
# EXPORT_SQUAD_DELAY_MS=400

# Optional: SQLite folder (local: ./data; Render: /var/data with mounted disk).
# DATA_DIR=./data
