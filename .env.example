# Required in production
JWT_SECRET=change-me-to-a-long-random-string

# API-Football (https://www.api-football.com/) — match results + team squads (player dropdown)
API_FOOTBALL_KEY=
# World Cup league id on api-sports (default: 1)
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026
# Sync every 15 minutes (milliseconds)
RESULTS_SYNC_INTERVAL_MS=900000
# Max fixture event requests per sync (first scorer)
RESULTS_SYNC_MAX_EVENTS=15

# Optional: allow sync without being a league owner
# ADMIN_SYNC_SECRET=

# Optional: SQLite folder (production: /data with a mounted volume).
# Do not set to /data locally unless that path exists and is writable.
# DATA_DIR=./data
